---
layout: base.njk
pagination:
  data: collections.tagList
  size: 1
  alias: tag
permalink: "/tags/{{ tag | slugify }}/"
eleventyComputed:
  title: "{{ tag }}"
---
<div class="content-header">
    <h1>Tagged: {{ tag }}</h1>
    <a href="/" class="clear-filter">Clear filter</a>
</div>

{% set matches = collections.posts | postsWithTag(tag) %}
{% if matches.length %}
<div class="feed">
    {% for post in matches %}
    <article class="post-card">
        <div class="tag-list">
            {% for t in post.data.tags %}
            <a href="/tags/{{ t | slugify }}/" class="post-tag">{{ t }}</a>
            {% endfor %}
        </div>
        <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
        <p class="post-meta">{{ post.data.date | readableDate }}</p>
        <p class="snippet">{{ post.data.snippet }}</p>
        <a href="{{ post.url }}" class="read-more-btn">Read more &rarr;</a>
    </article>
    {% endfor %}
</div>
{% else %}
<p class="empty-state">No posts with this tag yet.</p>
{% endif %}
