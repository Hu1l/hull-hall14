---
layout: base.njk
title: Home
description: Personal reflections on life, book notes, and philosophical debates.
---
<div class="content-header">
    <h1>Latest Posts</h1>
</div>

{% if collections.posts.length %}
<div class="feed">
    {% for post in collections.posts %}
    <article class="post-card">
        <div class="tag-list">
            {% for tag in post.data.tags %}
            <a href="/tags/{{ tag | slugify }}/" class="post-tag">{{ tag }}</a>
            {% endfor %}
        </div>
        <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
        <p class="post-meta">{{ post.data.date | readableDate }}</p>
        <p class="snippet">{{ post.data.snippet }}</p>
        <a href="{{ post.url }}" class="read-more-btn">Read more &rarr;</a>
    </article>
    {% endfor %}
</div>
{% else %}
<div class="empty-state">
    <p>No posts yet.</p>
    <a href="/admin/" class="read-more-btn">Write your first one &rarr;</a>
</div>
{% endif %}
